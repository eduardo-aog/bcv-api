{
  "name": "bcv-script",
  "version": "1.0.0",
  "description": "Script para cargar automaticamente las tasas de cambio de divisas del Banco Central de Venezuela",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prestart": "npm run build",
    "type-check": "tsc --noEmit",
    "scrape": "ts-node src/index.ts"
  },
  "keywords": [
    "scraping",
    "cheerio",
    "typescript"
  ],
  "author": "Eduardo Orozco",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.31",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
